        base_footprint:
          Value: true
        base_link:
          Value: true
        front_left_steering_link:
          Value: true
        front_left_wheel:
          Value: true
        front_right_steering_link:
          Value: true
        front_right_wheel:
          Value: true
        gps_link:
          Value: true
        imu_link:
          Value: true
        laser_link:
          Value: true
        odom:
